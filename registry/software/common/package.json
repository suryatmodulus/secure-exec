{
	"name": "@agent-os-pkgs/common",
	"version": "0.3.0-rc.1",
	"type": "module",
	"license": "Apache-2.0",
	"description": "Common WASM command set for secure-exec VMs (coreutils + sed + grep + gawk + findutils + diffutils + tar + gzip)",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"check-types": "tsc --noEmit"
	},
	"dependencies": {
		"@agent-os-pkgs/coreutils": "workspace:*",
		"@agent-os-pkgs/sed": "workspace:*",
		"@agent-os-pkgs/grep": "workspace:*",
		"@agent-os-pkgs/gawk": "workspace:*",
		"@agent-os-pkgs/findutils": "workspace:*",
		"@agent-os-pkgs/diffutils": "workspace:*",
		"@agent-os-pkgs/tar": "workspace:*",
		"@agent-os-pkgs/gzip": "workspace:*"
	},
	"devDependencies": {
		"@secure-exec/registry-types": "workspace:*",
		"@types/node": "^22.10.2",
		"typescript": "^5.9.2"
	}
}
