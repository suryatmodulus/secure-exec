{
	"name": "@agentos-software/build-essential",
	"version": "0.3.0-rc.2",
	"type": "module",
	"license": "Apache-2.0",
	"description": "Build-essential WASM command set for secure-exec VMs (common + git + curl)",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
