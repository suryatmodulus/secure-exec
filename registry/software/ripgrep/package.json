{
	"name": "@agentos-software/ripgrep",
	"version": "0.3.0-rc.2",
	"type": "module",
	"license": "Apache-2.0",
	"description": "ripgrep fast search for secure-exec VMs",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"dist/package",
		"bin"
