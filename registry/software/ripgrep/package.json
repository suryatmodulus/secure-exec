	"scripts": {
		"build": "tsc && node ../../scripts/assemble-dist-package.mjs",
		"check-types": "tsc --noEmit"
	},
	"devDependencies": {
		"@agentos-software/manifest": "workspace:*",
		"@types/node": "^22.10.2",
		"typescript": "^5.9.2"
	}
