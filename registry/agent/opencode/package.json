{
	"name": "@agentos-software/opencode",
	"version": "0.2.1",
	"type": "module",
	"license": "Apache-2.0",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"agentos-opencode-acp": "./dist/adapter.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "node ./scripts/build-opencode-acp.mjs && tsc && agentos-toolchain pack . --out dist/package --agent agentos-opencode-acp",
		"check-types": "tsc --noEmit"
	},
	"devDependencies": {
		"@agentos-software/manifest": "workspace:*",
		"@rivet-dev/agentos-toolchain": "workspace:*",
		"@types/node": "^22.10.2",
		"bun": "1.3.11",
		"typescript": "^5.7.2"
	}
}
