 use crate::os::fd::{AsFd, AsRawFd, BorrowedFd, FromRawFd, IntoRawFd};
 #[cfg(target_family = "unix")]
 use crate::os::unix::prelude::*;
+
+// host_fs FFI — provides real POSIX mode from the wasmVM host runtime.
+// WASI filestat does not include permission bits, so Rust std's stat()
+// returns a synthesized default (0555). These imports let us fetch the
+// actual mode stored in the virtual filesystem.
+#[cfg(target_os = "wasi")]
+mod host_fs {
+    #[link(wasm_import_module = "host_fs")]
+    unsafe extern "C" {
+        pub fn path_mode(path_ptr: *const u8, path_len: u32, follow_symlinks: u32) -> u32;
+        pub fn fd_mode(fd: i32) -> u32;
+        pub fn chmod(path_ptr: *const u8, path_len: u32, mode: u32) -> u32;
+    }
+}
+
 #[cfg(target_os = "wasi")]
 use crate::os::wasi::prelude::*;
 use crate::path::{Path, PathBuf};
@@ -1376,6 +1392,12 @@

         let mut stat: stat64 = unsafe { mem::zeroed() };
         cvt(unsafe { fstat64(fd, &mut stat) })?;
+        #[cfg(target_os = "wasi")]
+        {
+            let mode = unsafe { host_fs::fd_mode(fd as i32) };
+            if mode != 0 { stat.st_mode = mode as libc::mode_t; }
+        }
         Ok(FileAttr::from_stat64(stat))
     }

