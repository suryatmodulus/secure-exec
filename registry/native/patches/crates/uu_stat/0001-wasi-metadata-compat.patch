+
+    mod host_fs {
+        #[link(wasm_import_module = "host_fs")]
+        unsafe extern "C" {
+            pub fn path_mode(path_ptr: *const u8, path_len: u32, follow_symlinks: u32) -> u32;
+        }
+    }
+
+    pub fn mode_for_path(path: &Path, meta: &Metadata, follow_symlinks: bool) -> u32 {
+        let Some(path_str) = path.to_str() else {
+            return meta.mode();
+        };
+        let mode = unsafe {
+            host_fs::path_mode(
+                path_str.as_ptr(),
+                path_str.len() as u32,
+                if follow_symlinks { 1 } else { 0 },
+            )
+        };
+        if mode == 0 {
+            meta.mode()
+        } else {
+            mode
+        }
+    }
+}
