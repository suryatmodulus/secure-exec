+#[cfg(target_os = "wasi")]
+fn receive_sorted_chunk(receiver: &Receiver<Chunk>, settings: &GlobalSettings) -> Option<Chunk> {
+    let Ok(mut chunk) = receiver.recv() else {
+        return None;
+    };
+    chunk.with_dependent_mut(|_, contents| {
+        sort_by(&mut contents.lines, settings, &contents.line_data);
+    });
+    Some(chunk)
+}
+
+#[cfg(not(target_os = "wasi"))]
+fn receive_sorted_chunk(receiver: &Receiver<Chunk>, _settings: &GlobalSettings) -> Option<Chunk> {
+    receiver.recv().ok()
+}
