-pub fn split_paths(_unparsed: &OsStr) -> SplitPaths<'_> {
-    panic!("unsupported")
+pub fn split_paths(unparsed: &OsStr) -> SplitPaths<'_> {
+    // wasm32-wasip1 uses ':'-separated PATH-like lists, like Unix. (secure-exec
+    // pipeline-only codex port — codex parses PATH via env::split_paths.)
+    use crate::os::wasi::ffi::OsStrExt;
+    let bytes = unparsed.as_bytes();
+    let paths: crate::vec::Vec<PathBuf> = bytes
+        .split(|b| *b == b':')
+        .map(|seg| PathBuf::from(OsStr::from_bytes(seg)))
+        .collect();
+    SplitPaths { inner: paths.into_iter(), _marker: PhantomData }
 }

 impl<'a> Iterator for SplitPaths<'a> {
