+// wasmVM host FFI bindings for process and user identity syscalls.
+mod host_ffi {
+    #[link(wasm_import_module = "host_process")]
+    unsafe extern "C" {
+        pub fn proc_getpid(ret_pid: *mut u32) -> u32;
+        pub fn proc_getppid(ret_pid: *mut u32) -> u32;
+    }
+
+    #[link(wasm_import_module = "host_user")]
+    unsafe extern "C" {
+        pub fn getuid(ret_uid: *mut u32) -> u32;
+        pub fn getgid(ret_gid: *mut u32) -> u32;
+        pub fn geteuid(ret_uid: *mut u32) -> u32;
+        pub fn getegid(ret_gid: *mut u32) -> u32;
+    }
+}
