+static const char *find_pwd_in_env(char *const envp[]) {
+    if (!envp) return NULL;
+    for (int i = 0; envp[i]; i++) {
+        const char *entry = envp[i];
+        if (strncmp(entry, "PWD=", 4) == 0 && entry[4] == '/') {
+            return entry + 4;
+        }
+    }
+    return NULL;
+}
