diff --git a/libc-bottom-half/sources/host_getpid.c b/libc-bottom-half/sources/host_getpid.c
new file mode 100644
index 0000000..b20aeb0
--- /dev/null
+++ b/libc-bottom-half/sources/host_getpid.c
@@ -0,0 +1,34 @@
+// getpid() and getppid() via wasmVM host_process imports.
+//
+// Replaces wasi-libc's hardcoded getpid (which returns 42) and
+// adds getppid (which was #ifdef'd out) with implementations that
+// call our host_process.proc_getpid and host_process.proc_getppid.
+//
+// Import signatures match wasmvm/crates/wasi-ext/src/lib.rs exactly.
+
+#include <__errno.h>
+#include <stdint.h>
+#include <unistd.h>
+
+#define WASM_IMPORT(mod, fn) \
+    __attribute__((__import_module__(mod), __import_name__(fn)))
+
+WASM_IMPORT("host_process", "proc_getpid")
+uint32_t __host_proc_getpid(uint32_t *ret_pid);
+
+WASM_IMPORT("host_process", "proc_getppid")
+uint32_t __host_proc_getppid(uint32_t *ret_pid);
+
+pid_t getpid(void) {
+    uint32_t pid;
+    uint32_t err = __host_proc_getpid(&pid);
+    if (err != 0) return -1;
+    return (pid_t)pid;
+}
+
+pid_t getppid(void) {
+    uint32_t ppid;
+    uint32_t err = __host_proc_getppid(&ppid);
+    if (err != 0) return -1;
+    return (pid_t)ppid;
+}
