 // Helper to call `__wasilibc_find_relpath` and return an already-managed
--- a/libc-bottom-half/sources/preopens.c
+++ b/libc-bottom-half/sources/preopens.c
@@ -11,6 +11,7 @@
 #include <stdlib.h>
 #include <string.h>
 #include <sysexits.h>
+#include <unistd.h>
 #include <wasi/api.h>
 #include <wasi/libc-find-relpath.h>
 #include <wasi/libc.h>
@@ -98,6 +99,91 @@ static const char *strip_prefixes(const char *path) {
     return path;
 }
 
+static const char *strip_relative_prefixes(const char *path) {
+    while (1) {
+        if (path[0] == '.' && path[1] == '/') {
+            path += 2;
+        } else if (path[0] == '.' && path[1] == 0) {
+            path++;
+        } else {
+            break;
+        }
+    }
+
+    return path;
+}
+
+static int build_abspath_from_cwd(const char *path, char **abspath_out) {
+    const char *suffix = strip_relative_prefixes(path);
+    char *cwd = getcwd(NULL, 0);
+    if (cwd == NULL)
+        return -1;
+
+    size_t cwd_len = strlen(cwd);
+    size_t suffix_len = strlen(suffix);
+    int need_slash = suffix_len > 0 && cwd_len > 0 && cwd[cwd_len - 1] != '/';
+    char *buf = malloc(cwd_len + need_slash + suffix_len + 1);
+    if (buf == NULL) {
+        free(cwd);
+        errno = ENOMEM;
+        return -1;
+    }
+
+    memcpy(buf, cwd, cwd_len);
+    size_t off = cwd_len;
+    if (need_slash)
+        buf[off++] = '/';
+    memcpy(buf + off, suffix, suffix_len);
+    buf[off + suffix_len] = '\0';
+
+    free(cwd);
+    *abspath_out = buf;
+    return 0;
+}
+
+int __wasilibc_find_relpath_fallback(
+    const char *path,
+    const char **abs_prefix,
+    char **relative_buf,
+    size_t *relative_buf_len,
+    int can_realloc
+) {
+    char *owned_abspath = NULL;
+    const char *abspath = path;
+    if (path[0] != '/') {
+        if (build_abspath_from_cwd(path, &owned_abspath) != 0)
+            return -1;
+        abspath = owned_abspath;
+    }
+
+    const char *rel;
+    int fd = __wasilibc_find_abspath(abspath, abs_prefix, &rel);
+    if (fd == -1) {
+        free(owned_abspath);
+        return -1;
+    }
+
+    size_t rel_len = strlen(rel);
+    if (*relative_buf_len < rel_len + 1) {
+        if (!can_realloc) {
+            free(owned_abspath);
+            errno = ERANGE;
+            return -1;
+        }
+        char *tmp = realloc(*relative_buf, rel_len + 1);
+        if (tmp == NULL) {
+            free(owned_abspath);
+            errno = ENOMEM;
+            return -1;
+        }
+        *relative_buf = tmp;
+        *relative_buf_len = rel_len + 1;
+    }
+    strcpy(*relative_buf, rel);
+    free(owned_abspath);
+    return fd;
+}
+
