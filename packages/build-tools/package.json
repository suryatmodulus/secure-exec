{
	"name": "@secure-exec/build-tools",
	"version": "0.2.1",
	"private": true,
	"type": "module",
	"license": "Apache-2.0",
	"files": [
		"scripts",
		"README.md"
	],
	"scripts": {
		"build:base-filesystem": "node ./scripts/build-base-filesystem.mjs",
		"build:protocol": "node ./scripts/compile-sidecar-protocol.mjs",
		"build:v8-bridge": "node ./scripts/build-v8-bridge.mjs",
		"snapshot:alpine-defaults": "node ./scripts/snapshot-alpine-defaults.mjs",
		"check-types": "node --check ./scripts/build-base-filesystem.mjs && node --check ./scripts/build-v8-bridge.mjs && node --check ./scripts/compile-sidecar-protocol.mjs && node --check ./scripts/snapshot-alpine-defaults.mjs",
		"build": "pnpm run check-types",
		"test": "pnpm run check-types"
	},
	"dependencies": {
		"@bare-ts/tools": "0.15.0",
		"esbuild": "^0.27.4",
		"node-stdlib-browser": "^1.3.1",
		"undici": "^7.24.6",
		"web-streams-polyfill": "^3.3.3"
	}
}
