{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://secureexec.dev/schemas/agentos-package.schema.json",
  "title": "agentos-package.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["acpEntrypoint"],
      "properties": {
        "acpEntrypoint": {
          "type": "string",
          "minLength": 1
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "launchArgs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "snapshot": {
          "type": "boolean"
        }
      }
    },
    "provides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source", "target"],
            "properties": {
              "source": {
                "type": "string",
                "minLength": 1
              },
              "target": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
